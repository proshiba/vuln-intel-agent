{
  "$defs": {
    "Category": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "Category",
      "type": "object"
    },
    "CollectorKind": {
      "enum": [
        "csaf",
        "json_api",
        "feed",
        "html",
        "browser",
        "pdf"
      ],
      "title": "CollectorKind",
      "type": "string"
    },
    "SourceDefinition": {
      "additionalProperties": false,
      "properties": {
        "advisory_url": {
          "title": "Advisory Url",
          "type": "string"
        },
        "allowed_hosts": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Hosts",
          "type": "array"
        },
        "alternative_channels": {
          "items": {
            "type": "string"
          },
          "title": "Alternative Channels",
          "type": "array"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "collector": {
          "anyOf": [
            {
              "$ref": "#/$defs/CollectorKind"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "content_types": {
          "items": {
            "type": "string"
          },
          "title": "Content Types",
          "type": "array"
        },
        "detail_collector": {
          "anyOf": [
            {
              "$ref": "#/$defs/CollectorKind"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "fallback_collectors": {
          "items": {
            "$ref": "#/$defs/CollectorKind"
          },
          "title": "Fallback Collectors",
          "type": "array"
        },
        "feed_formats": {
          "items": {
            "type": "string"
          },
          "title": "Feed Formats",
          "type": "array"
        },
        "feed_status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Feed Status"
        },
        "feed_urls": {
          "items": {
            "type": "string"
          },
          "title": "Feed Urls",
          "type": "array"
        },
        "id": {
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "title": "Id",
          "type": "string"
        },
        "max_detail_fetches": {
          "default": 100,
          "maximum": 1000,
          "minimum": 0,
          "title": "Max Detail Fetches",
          "type": "integer"
        },
        "max_items": {
          "default": 1000,
          "exclusiveMinimum": 0,
          "maximum": 10000,
          "title": "Max Items",
          "type": "integer"
        },
        "max_response_bytes": {
          "default": 20000000,
          "exclusiveMinimum": 0,
          "title": "Max Response Bytes",
          "type": "integer"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "parser": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parser"
        },
        "products": {
          "items": {
            "type": "string"
          },
          "title": "Products",
          "type": "array"
        },
        "rate_limit_per_second": {
          "default": 1.0,
          "exclusiveMinimum": 0,
          "maximum": 20,
          "title": "Rate Limit Per Second",
          "type": "number"
        },
        "role": {
          "$ref": "#/$defs/SourceRole",
          "default": "advisory"
        },
        "selectors": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Selectors",
          "type": "object"
        },
        "tier": {
          "$ref": "#/$defs/Tier",
          "default": "daily"
        },
        "timeout_seconds": {
          "default": 30.0,
          "exclusiveMinimum": 0,
          "maximum": 120,
          "title": "Timeout Seconds",
          "type": "number"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "vendor": {
          "title": "Vendor",
          "type": "string"
        },
        "wait_for": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wait For"
        }
      },
      "required": [
        "id",
        "category",
        "vendor",
        "advisory_url"
      ],
      "title": "SourceDefinition",
      "type": "object"
    },
    "SourceRole": {
      "enum": [
        "advisory",
        "enrichment"
      ],
      "title": "SourceRole",
      "type": "string"
    },
    "Tier": {
      "enum": [
        "edge",
        "daily"
      ],
      "title": "Tier",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "as_of": {
      "title": "As Of",
      "type": "string"
    },
    "categories": {
      "items": {
        "$ref": "#/$defs/Category"
      },
      "title": "Categories",
      "type": "array"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/SourceDefinition"
      },
      "title": "Sources",
      "type": "array"
    }
  },
  "required": [
    "as_of",
    "categories",
    "sources"
  ],
  "title": "SourceRegistry",
  "type": "object"
}
