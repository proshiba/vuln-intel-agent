{
  "$defs": {
    "AdvisoryDecision": {
      "additionalProperties": false,
      "properties": {
        "priority": {
          "$ref": "#/$defs/Priority",
          "default": "INFO"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        }
      },
      "title": "AdvisoryDecision",
      "type": "object"
    },
    "AdvisoryEnrichment": {
      "additionalProperties": false,
      "properties": {
        "asset_match": {
          "default": false,
          "title": "Asset Match",
          "type": "boolean"
        },
        "cisa_kev": {
          "default": false,
          "title": "Cisa Kev",
          "type": "boolean"
        },
        "internet_exposed": {
          "default": false,
          "title": "Internet Exposed",
          "type": "boolean"
        },
        "matched_asset_ids": {
          "items": {
            "type": "string"
          },
          "title": "Matched Asset Ids",
          "type": "array"
        }
      },
      "title": "AdvisoryEnrichment",
      "type": "object"
    },
    "AdvisoryFacts": {
      "additionalProperties": false,
      "properties": {
        "affected_versions": {
          "items": {
            "type": "string"
          },
          "title": "Affected Versions",
          "type": "array"
        },
        "authentication_required": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Authentication Required"
        },
        "cves": {
          "items": {
            "type": "string"
          },
          "title": "Cves",
          "type": "array"
        },
        "cvss_score": {
          "anyOf": [
            {
              "maximum": 10,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cvss Score"
        },
        "cvss_vector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cvss Vector"
        },
        "fixed_versions": {
          "items": {
            "type": "string"
          },
          "title": "Fixed Versions",
          "type": "array"
        },
        "known_exploited": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Known Exploited"
        },
        "mitigations": {
          "items": {
            "type": "string"
          },
          "title": "Mitigations",
          "type": "array"
        },
        "poc_public": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Poc Public"
        },
        "products": {
          "items": {
            "type": "string"
          },
          "title": "Products",
          "type": "array"
        },
        "remote": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote"
        },
        "vendor_severity": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vendor Severity"
        }
      },
      "title": "AdvisoryFacts",
      "type": "object"
    },
    "AdvisoryStatus": {
      "enum": [
        "active",
        "withdrawn"
      ],
      "title": "AdvisoryStatus",
      "type": "string"
    },
    "AiMetadata": {
      "additionalProperties": false,
      "properties": {
        "affected_assets": {
          "items": {
            "type": "string"
          },
          "title": "Affected Assets",
          "type": "array"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "evidence_urls": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Urls",
          "type": "array"
        },
        "exposure_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Exposure Conditions",
          "type": "array"
        },
        "input_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Hash"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "prompt_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Version"
        },
        "recommended_actions": {
          "items": {
            "type": "string"
          },
          "title": "Recommended Actions",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/AiStatus",
          "default": "pending"
        },
        "summary_ja": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary Ja"
        },
        "uncertainties": {
          "items": {
            "type": "string"
          },
          "title": "Uncertainties",
          "type": "array"
        }
      },
      "title": "AiMetadata",
      "type": "object"
    },
    "AiStatus": {
      "enum": [
        "pending",
        "success",
        "skipped",
        "failed",
        "refused"
      ],
      "title": "AiStatus",
      "type": "string"
    },
    "Priority": {
      "enum": [
        "P1",
        "P2",
        "P3",
        "INFO"
      ],
      "title": "Priority",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Sha256",
          "type": "string"
        },
        "extractor_version": {
          "title": "Extractor Version",
          "type": "string"
        },
        "source_type": {
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_type",
        "content_sha256",
        "extractor_version"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "ai": {
      "$ref": "#/$defs/AiMetadata"
    },
    "body_excerpt": {
      "default": "",
      "title": "Body Excerpt",
      "type": "string"
    },
    "canonical_id": {
      "title": "Canonical Id",
      "type": "string"
    },
    "decision": {
      "$ref": "#/$defs/AdvisoryDecision"
    },
    "enrichment": {
      "$ref": "#/$defs/AdvisoryEnrichment"
    },
    "facts": {
      "$ref": "#/$defs/AdvisoryFacts"
    },
    "first_seen_at": {
      "format": "date-time",
      "title": "First Seen At",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "published_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Published At"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "source_url": {
      "title": "Source Url",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/AdvisoryStatus",
      "default": "active"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    },
    "vendor": {
      "title": "Vendor",
      "type": "string"
    },
    "vendor_advisory_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Vendor Advisory Id"
    }
  },
  "required": [
    "canonical_id",
    "source_id",
    "vendor",
    "title",
    "source_url",
    "first_seen_at",
    "facts",
    "provenance"
  ],
  "title": "Advisory",
  "type": "object"
}
